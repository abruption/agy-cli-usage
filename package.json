{
  "name": "agy-cli-usage",
  "version": "0.4.0",
  "description": "Headless usage/quota monitor for the Antigravity CLI (agy) — reads Cloud Code quota directly, with a PTY fallback. No IDE required.",
  "type": "module",
  "types": "dist/src/main.d.ts",
  "bin": {
    "agy-cli-usage": "dist/src/main.js",
    "agy-usage": "dist/src/main.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test dist/test/unit.test.js",
    "start": "tsc && node dist/src/main.js",
    "serve": "tsc && node dist/src/server.js",
    "prepack": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "antigravity",
    "agy",
    "gemini",
    "code-assist",
    "quota",
    "usage",
    "cli",
    "rate-limit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abruption/agy-cli-usage.git"
  },
  "homepage": "https://github.com/abruption/agy-cli-usage#readme",
  "bugs": {
    "url": "https://github.com/abruption/agy-cli-usage/issues"
  },
  "author": "abruption",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@xterm/headless": "^6.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
